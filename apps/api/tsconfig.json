{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "strict": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": ["node"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "outDir": "dist",
    "rootDir": ".",
    "allowJs": true
  },
  "include": ["src/**/*", "api/**/*", "eslint.config.mjs"],
  "exclude": ["node_modules", "dist"]
}
